<!DOCTYPE html>
<html>
<head>
    <title>MSP Task Manager</title>

    <link rel="stylesheet" href="/css/app.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>

<body>

<div class="sidebar">
    <h2>MSP Ops</h2>

    <a href="/">Dashboard</a>
    <a href="/customers">Customers</a>
    <a href="/templates">Templates</a>
    <a href="/schedules">Schedules</a>
    <a href="/assignments">Assignments</a>
</div>

<div class="main">
    <%- body %>
</div>

<!-- Global Task Drawer -->
<div id="taskDrawer" style="
    position: fixed;
    top: 0;
    right: -520px;
    width: 520px;
    height: 100%;
    background: white;
    box-shadow: -5px 0 20px rgba(0,0,0,0.15);
    transition: 0.3s;
    padding: 20px;
    overflow-y: auto;
    z-index: 999;
">
    <div class="d-flex justify-content-between">
        <h4 id="drawerTitle"></h4>
        <button onclick="closeDrawer()" class="btn btn-danger btn-sm">X</button>
    </div>

    <div id="drawerMeta" class="text-muted"></div>

    <hr>

    <div id="drawerSteps"></div>

    <button class="btn btn-success mt-3 w-100" onclick="completeTask()">
        Complete Task
    </button>
</div>

<script src="/js/app.js"></script>

</body>
</html>