<!DOCTYPE html>
<html>
<head>
    <title>Elite Task Manager</title>
    <link rel="stylesheet" href="/css/app.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>
<div class="sidebar">
    <div class="d-flex gap-2">
		<h2>Elite Operations</h2>
		<button class="btn btn-secondary" id="logoutBtn" style="display: none">Logout</button>
	</div>

    <a href="/">Dashboard</a>
    <a href="/customers">Customer</a>
    <a href="/templates">Templates</a>
    <a href="/schedules">Schedules</a>
    <a href="/assignments">Assignments</a>
</div>

<div class="main">
    <%- body %>
</div>
<div id="globalModal" class="overlay-modal hidden">
    <div class="modal-content" id="globalModalContent"></div>
</div>
<!-- GLOBAL SCRIPTS -->
<script src="/js/app.js"></script>
<script src="/js/components/searchable-select.js"></script>
<script src="/js/components/form-utils.js"></script>
<script type="text/javascript">
    document.getElementById("logoutBtn").addEventListener('click', () => {
        window.location.href = "/auth/logout";
    });
</script>

<!-- PAGE SCRIPTS -->
<%- scripts || '' %>
</body>
</html>