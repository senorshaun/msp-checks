<h2 class="mb-3">Dashboard</h2>
<div id="drawerOverlay" onclick="closeDrawer()"></div>
<div id="filterOverlay" onclick="closeSidebar()"></div>

<div id="sidebar">
    <div class="p-3">
	    <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Task View</h5>
            <button class="btn btn-sm btn-danger" onclick="closeSidebar()">X</button>
        </div>
	    <div class="mb-3 d-flex gap-2">
			<button class="btn btn-primary btn-sm" onclick="toggleView('calendar')">Calendar</button>
			<button class="btn btn-primary btn-sm" onclick="toggleView('list')">List</button>
		</div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Filters</h5>
        </div>
        <!-- Customers -->
        <div class="mb-3">
            <strong>Customers</strong>
            <div id="customerFilterContainer"></div>
        </div>
        <!-- Status -->
        <div>
            <strong>Status</strong>
            <div id="statusLegend" class="d-flex flex-column gap-1 mt-2"></div>
        </div>
    </div>
</div>

<!-- MAIN CONTENT -->
<div class="p-3">
	<div id="boardToolbar" class="d-flex justify-content-between mb-2">
		<div>
			<button class="btn btn-sm btn-outline-secondary" onclick="openSidebar()">☰ Filters</button>
			<button class="btn btn-sm btn-outline-secondary" onclick="changeWeek(-1)">←</button>
			<button class="btn btn-sm btn-outline-secondary" onclick="resetWeek()">Today</button>
			<button class="btn btn-sm btn-outline-secondary" onclick="changeWeek(1)">→</button>
		</div>
		<strong id="dateLabel"></strong>
	</div>
    <div id="boardView" class="board"></div>
    <div id="listView" style="display:none;"></div>
</div>
<div id="taskDrawer">
    <div class="d-flex justify-content-between">
        <h4 id="drawerTitle"></h4>
        <button onclick="closeDrawer()" class="btn btn-danger btn-sm">X</button>
    </div>
    <div id="drawerMeta" class="text-muted"></div>
    <hr>
    <div id="drawerSteps"></div>
    <button class="btn btn-success mt-3 w-100" onclick="completeTask()">
        Complete Task
    </button>
</div>

<script>
    window.__DATA__ = <%- JSON.stringify({
		customers,
        items
	}) %>;
</script>
<% scripts = `
<script src="/js/pages/dashboard.js"></script>
` %>
