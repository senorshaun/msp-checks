<h2>Templates</h2>

<div class="card mb-3">
    <form method="POST" action="/templates/create"
        onsubmit="if(!this.name.value.trim()){alert('Name required');return false;}">
		<div class="d-flex gap-2">
			<input class="form-control" name="name" placeholder="New Template">
            <button class="btn btn-success">+ Add</button>
        </div>
    </form>
</div>

<div class="card">
    <% templates.forEach(t => { %>
        <div class="d-flex justify-content-between p-2 border-bottom">
            <a href="/templates/<%= t.id %>">
                <%= t.name %>
            </a>
        </div>
    <% }) %>
</div>