<h2 class="mb-0">Templates</h2>

<div class="d-flex gap-2">
	<button class="btn btn-primary" id="createTemplateBtn">Create Template</button>
</div>

<div id="templateList" class="d-flex flex-column gap-3">
	<% if (!templates || templates.length === 0) { %>
		<div class="text-muted">No templates found.</div>
	<% } %>
	<% templates.forEach(template => { %>
		<div class="card msp-card template-card" data-id="<%= template.id %>">
			<div class="card-body d-flex justify-content-between align-items-center">
				<div>
					<div class="fw-semibold template-open-btn" style="cursor:pointer;">
						<%= template.name %>
					</div>
					<div class="text-muted small mt-1">
						<% if (template.description) { %>
							<div><%= template.description %></div>
						<% } %>
					</div>
				</div>
				<div class="d-flex gap-2">
					<button class="btn btn-outline-danger btn-sm delete-template-btn">Delete</button>
				</div>
			</div>
		</div>
	<% }) %>
</div>

<script>
	window.__DATA__ = <%- JSON.stringify({
		templates
	}) %>;
</script>
<% scripts = `
<script src="/js/pages/templates.js"></script>
` %>