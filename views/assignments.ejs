<h2 class="mb-0">Assignments</h2>

<div class="d-flex gap-2">
    <button class="btn btn-primary" id="createAssignmentBtn">Create Assignment</button>
</div>

<div id="assignmentList" class="d-flex flex-column gap-3">
	<% if (!assignments || assignments.length === 0) { %>
		<div class="text-muted">No assignments found.</div>
	<% } %>
	<% assignments.forEach(a => { %>
		<div class="card msp-card assignment-card" data-id="<%= a.id %>">
			<div class="card-body d-flex justify-content-between align-items-center">
				<div>
					<div class="fw-semibold">
						<%= a.customer_name || 'Unknown Customer' %>
					</div>
					<div class="text-muted small mt-1">
						<div>Template: <%= a.template_name || '—' %></div>
						<div>Schedule: <%= a.schedule_name || '—' %></div>
						<% if (a.enabled !== undefined) { %>
							<div>Status: <%= a.enabled ? 'Enabled' : 'Disabled' %></div>
						<% } %>
					</div>
				</div>
				<div class="d-flex gap-2">
					<button class="btn btn-primary btn-sm edit-assignment-btn">Edit</button>
					<button class="btn btn-outline-danger btn-sm delete-assignment-btn">Delete</button>
				</div>
			</div>
		</div>
	<% }) %>
</div>

<script>
    window.__DATA__ = <%- JSON.stringify({
		assignments,
        customers,
        templates,
        schedules,
		groups
	}) %>;
</script>
<% scripts = `
<script src="/js/pages/assignments.js"></script>
` %>