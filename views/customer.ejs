<h2><%=customer.name%></h2>

<div class="form-group mb-3">
    <label>Select Customer</label>
    <div id="customerSwitcherContainer"></div>
</div>

<div class="d-flex gap-2 mb-3">
    <button class="btn btn-primary" onclick="openAssignModal()">Add Assignment</button>
    <button class="btn btn-secondary" onclick="openCopyModal()">Copy From</button>
</div>

<hr>

<% assignments.forEach(a => { %>
<div class="card mb-2">
    <div class="card-row">
        <div class="card-content">
            <div class="card-title"><%= a.template_name %></div>
            <div class="card-subtitle"><%= a.schedule_name %></div>
        </div>

        <div class="card-actions">
            <div 
                class="group-select" 
                data-assignment-id="<%= a.id %>">
				data-current-group="<%= a.group_id %>"
                <%- buildSearchableSelect({
                    name: `group_${a.id}`,
                    data: groups,
                    placeholder: 'Select Group'
                }) %>
            </div>
        </div>
    </div>
</div>
<% }) %>

<script>
    window.__DATA__ = {
		customerId: <%= customer.id %>,
		templates: <%- JSON.stringify(templates) %>,
		schedules: <%- JSON.stringify(schedules) %>,
		groups: <%- JSON.stringify(groups) %>,
		customers: <%- JSON.stringify(customers) %>
	};
</script>
<script src="/js/pages/customer.js"></script>