<h2 class="mb-0">Customer</h2>

<div class="d-flex gap-2">
	<div id="customerSwitcherContainer"></div>
	<button class="btn btn-primary" id="addAssignmentBtn">Add Assignment</button>
	<button class="btn btn-secondary" id="copyAssignmentBtn">Copy From</button>
</div>

<div id="assignmentList" class="d-flex flex-column gap-3">
    <% assignments.forEach(a => { %>
        <div class="card msp-card assignment-card" data-id="<%= a.id %>">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="card-title fw-semibold">
                        <%= a.template_name %>
                    </div>
                    <div class="text-muted small">
                        Group:
                        <span class="group-name">
                            <%= a.group_name || 'Unassigned' %>
                        </span>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <div 
                        class="group-select"
                        data-assignment-id="<%= a.id %>"
                        data-current-group="<%= a.group_id %>">
                    </div>
                    <button 
                        class="btn btn-outline-danger btn-sm delete-assignment"
                        data-id="<%= a.id %>">
                        Remove
                    </button>
                </div>

            </div>
        </div>
    <% }) %>
</div>

<script>
    window.__DATA__ = <%- JSON.stringify({
        customer,
        assignments,
        groups,
        customers,
		templates,
		schedules
    }) %>;
</script>
<% scripts = `
<script src="/js/pages/customer.js"></script>
` %>